diff --git a/platform/virt/service.c b/platform/virt/service.c
index bc1de08b..861538a6 100644
--- a/platform/virt/service.c
+++ b/platform/virt/service.c
@@ -38,6 +38,14 @@ static RO_AFTER_INIT u8 gpio_key_power = -1;
 
 BSS_RO_AFTER_INIT struct uefi_boot_params boot_params;
 
+static void init_platform_features(void)
+{
+    void *dtb = pointer_from_u64(DEVICETREE_BLOB_BASE);
+    dt_node root = dtb_get_root(dtb);
+    if (dtb_get_prop(dtb, root, ss("ant,hvf-prohibit-dc-zva")) != INVALID_ADDRESS)
+        aarch64_set_dc_zva_enabled(false);
+}
+
 u64 machine_random_seed(void)
 {
 #if 0 // gcc not taking +rng feature modifier...encode manually?
@@ -367,6 +375,7 @@ void __attribute__((noreturn)) start(u64 x0, u64 x1)
     }
 
     init_debug("calling init_mmu\n");
+    init_platform_features();
     init_mmu(device_base, u64_from_pointer(init_setup_stack));
 
     while (1);
diff --git a/src/runtime/memops.c b/src/runtime/memops.c
index 3f683de5..351a6c7f 100644
--- a/src/runtime/memops.c
+++ b/src/runtime/memops.c
@@ -125,14 +125,21 @@ void runtime_memcpy(void *a, const void *b, bytes len)
 }
 
 #if defined(__aarch64__)
+boolean aarch64_dc_zva_enabled = true;
+
+void aarch64_set_dc_zva_enabled(boolean enabled)
+{
+    aarch64_dc_zva_enabled = enabled;
+}
+
 void zero(void *x, bytes length)
 {
     u8 *a = x;
     bytes len = length;
     u64 dczid;
     asm volatile("mrs %0, DCZID_EL0" : "=r"(dczid));
-    if (!(dczid & (1u << 4))) {         /* DZP clear: DC ZVA not prohibited */
+    if (aarch64_dc_zva_enabled && !(dczid & (1u << 4))) { /* DZP clear: DC ZVA not prohibited */
         bytes block_size = 4ull << (dczid & 0xf); /* 64 B on Graviton2/Cortex-A72 */
         u64 ctr;
         asm volatile("mrs %0, CTR_EL0" : "=r"(ctr));
         block_size = MAX(block_size, 4ull << ((ctr >> 16) & 0xf));
